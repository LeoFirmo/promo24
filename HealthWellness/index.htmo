    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Estilos customizados para replicar as classes nativas do site -->
    <style>
        :root {
            --new-primary: #B3001B;
            --new-primary-dark: #931F1D;
            --new-blue-light: #3977a4;
            --new-blue-dark: #2A324B;
            --new-light: #E1E5EE;
            --bs-light-rgb: 225, 229, 238;
            --bs-font-sans-serif: 'Poppins', sans-serif;
        }

        body {
            /* font-family: Arial, sans-serif; */
            font-family: 'Poppins', sans-serif;
            background-color: #ffffff;
            color: #333;
        }

        .heading-2 {
            font-size: 2.5rem;
            font-weight: 800;
        }

        .heading-3 {
            font-size: 2rem;
            font-weight: 700;
        }

        .heading-4 {
            font-size: 1.25rem;
            font-weight: 700;
        }

        .theme-border-radius {
            border-radius: 1.25rem;
            overflow: hidden;
        }

        .theme-border-radius-bt {
            border-radius: 1.25rem;
            border-top-left-radius: 10px;
            border-top-right-radius: 10px;
            overflow: hidden;
        }

        .theme-border-radius-sm {
            border-radius: 0.75rem;
            overflow: hidden;
        }

        .border-gray {
            border-color: #e0e0e0 !important;
        }

        .border-primary-new {
            border: 2px solid var(--new-primary);
        }

        .btn-primary-new {
            /* background-color: #f59e0b; */
            background-color: #FFD814;
            color: black;
            font-size: 1.5rem;
            font-weight: bold;
            padding: 1rem 2rem;
            border-radius: 50px;
            text-transform: uppercase;
            text-decoration: none;
            transition: all 0.3s ease;
            border: none;
        }

        .btn-primary-new:hover {
            background-color: #F7CA00;
            color: black;
            transform: scale(1.05);
        }

        .blue-dark-bg {
            background-color: var(--new-blue-dark);
            background: linear-gradient(180deg, #2A324B 0.45%, #48BEFF 199.14%);
        }

        .blue-light-bg {
            background-color: #2A324B;
            /* Azul claro */
        }

        .red-gradient-bg {
            background: linear-gradient(135deg, #B3001B, #931F1D);
            background: linear-gradient(135deg, #B3001B, #931F1D);
        }


        .p-2-5 {
            padding: 0.75rem;
        }

        .faqs-bg {
            background-color: #f8fafc;
        }

        .reference-text {
            font-size: 0.85rem;
            color: #64748b;
        }

        .money-back-badge {
            /* margin-top: -3rem; */
            /* margin-top: -40%; */
            border-radius: 50%;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);

        }


        .modal-label {
            background: none;
            border: none;
            position: absolute;
            bottom: 10px;
            right: 10px;
            background-color: rgba(255, 255, 255, 0.8);
            border-radius: 50%;
            padding: 10px;
        }

        .bg-light {
            --bs-bg-opacity: 1;
            background-color: rgba(var(--bs-light-rgb), var(--bs-bg-opacity)) !important;
        }

        .gfw {
            content: "";
            position: absolute;
            top: 11%;
            bottom: 0;
            left: 0;
            right: 0;
            background-color: var(--new-blue-light);
            border-radius: 3.125rem;
        }

        /* -------------- */
        .promo-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .75);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 999999;
            padding: 20px;
        }

        .promo-box {
            background: white;
            width: 100%;
            max-width: 480px;
            border-radius: 24px;
            padding: 35px;
            text-align: center;
            position: relative;
            font-family: Poppins, sans-serif;
            animation: popup .3s ease;
        }

        @keyframes popup {
            from {
                transform: scale(.9);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        .close-btn {
            position: absolute;
            top: 15px;
            right: 15px;
            border: none;
            background: transparent;
            font-size: 22px;
            cursor: pointer;
        }

        .promo-box h2 {
            font-size: 32px;
            margin-bottom: 15px;
            font-weight: 700;
        }

        .promo-box p {
            font-size: 18px;
            color: #555;
            margin-bottom: 30px;
        }

        .promo-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .promo-btn {
            padding: 16px 28px;
            border-radius: 14px;
            text-decoration: none;
            font-weight: 700;
            transition: .3s;
            border: none;
            cursor: pointer;
        }

        .yes-btn {
            background: #22c55e;
            color: white;
        }

        .yes-btn:hover {
            transform: translateY(-2px);
        }

        .no-btn {
            background: #e5e7eb;
        }

        .promo-small {
            display: block;
            margin-top: 20px;
            font-size: 12px;
            color: #777;
        }

        body.modal-open {
            overflow: hidden;
        }
    </style>
</head>

